{
  "name": "absolute-motion-backend",
  "version": "0.1.0",
  "description": "Backend de renderização de anúncios animados (Seedance/Kling + ElevenLabs + FFmpeg).",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:all": "node dev.mjs",
    "setup": "npm install && npm --prefix frontend install",
    "start": "node --loader tsx dist/server.js",
    "build": "tsc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@fal-ai/client": "^1.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
