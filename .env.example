# ─────────────────────────────────────────────────────────────
# ABSOLUTE MOTION — variáveis de ambiente
# Copie para .env e preencha. NUNCA versione o .env real.
# Tudo que estiver vazio/placeholder roda em "modo demo" automaticamente.
# ─────────────────────────────────────────────────────────────

# ── 1) Motor criativo (roteiro, cenas, prompts) ──
# console.anthropic.com → Settings → API Keys (adicione US$5–10 de crédito em Billing)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ── 2) Imagem + vídeo (FLUX / Seedance / Kling) via fal.ai ──
# fal.ai → Dashboard → Keys (adicione saldo em Billing)
FAL_KEY=xxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxx

# ── 3) Narração + timestamps de legenda ──
# elevenlabs.io → perfil → Profile + API Key
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# Voice IDs: usam vozes públicas como default. Customize com suas vozes:
# (elevenlabs.io → Voices → VoiceLab → ícone share → copie o ID)
VOICE_ID_PREMIUM=
VOICE_ID_ENERGETICA_MASC=
VOICE_ID_ENERGETICA_FEM=
VOICE_ID_CALMA_MASC=
VOICE_ID_CALMA_FEM=

# ── 4) Armazenamento dos vídeos (Cloudflare R2 — compatível com S3) ──
# dash.cloudflare.com → R2 → cria bucket → Manage R2 API Tokens (Read & Write)
R2_ACCOUNT_ID=xxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxx
R2_BUCKET=absolute-motion-videos
R2_PUBLIC_URL=https://cdn.seudominio.com

# ── 5) Banco de dados + Auth (Supabase) ──
# supabase.com → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=xxxxxxxx          # service_role — NUNCA no frontend
SUPABASE_ANON_KEY=xxxxxxxx             # anon/public — usada pelo frontend/auth

# ── 6) Cobrança (Stripe) ──
# dashboard.stripe.com → Developers → API keys (use as de Test Mode agora)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
# Developers → Webhooks → endpoint /webhooks/stripe → "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
# Catálogo de Produtos → crie os planos → copie os IDs price_...
STRIPE_PRICE_STARTER=price_xxxxxxxx
STRIPE_PRICE_PRO=price_xxxxxxxx

# ── 7) Rastreio de erros (Sentry) — opcional ──
# sentry.io → novo projeto (Node) → copie o DSN
SENTRY_DSN=https://xxxx@oxxx.ingest.sentry.io/xxx

# ── 8) Fila durável (Inngest) — opcional (escala) ──
# app.inngest.com → projeto → Event Key + Signing Key
INNGEST_EVENT_KEY=xxxxxxxx
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxx
# Enquanto não migrar p/ Inngest, a fila roda em processo com esta concorrência:
QUEUE_CONCURRENCY=2

# ── 9) Trilhas de fundo (opcional) — URLs de MP3 royalty-free ──
MUSIC_CINEMATIC=
MUSIC_UPBEAT=
MUSIC_CORPORATE=
MUSIC_CHILL=

# ── 10) Diversos ──
APP_URL=http://localhost:5173        # base do frontend (redirect do Stripe)
DEMO_VIDEO_URL=                      # vídeo de exemplo do modo demo (opcional)
PORT=8787
